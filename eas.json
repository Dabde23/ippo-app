{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "autoIncrement": true,
      "android": {
        "distribution": "internal",
        "buildType": "app-bundle"
      },
      "ios": {
        "distribution": "store"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleTeamId": "642PG4M63T"
      }
    },
    "production": {}
  }
}
